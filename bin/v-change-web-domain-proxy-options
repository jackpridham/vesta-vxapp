#!/bin/bash
# info: change web domain native proxy options
# options: USER DOMAIN MODE TARGET [PROFILE] [PRESERVE_HOST] [TIMEOUT] [HEADERS] [RESTART]
#
# The function configures the Vortex native nginx redirect/proxy template.


#----------------------------------------------------------#
#                    Variable&Function                     #
#----------------------------------------------------------#

# Argument definition
user=$1
domain=$2
domain_idn=$2
mode=$3
target=$4
profile=${5-standard}
preserve_host=${6-yes}
timeout=${7-60}
headers=$8
restart=$9
default_extentions="jpg,jpeg,gif,png,ico,svg,css,zip,tgz,gz,rar,bz2,doc,xls,exe,pdf,ppt,txt,odt,ods,odp,odf,tar,wav,bmp,rtf,js,mp3,avi,mpeg,flv,woff,woff2"

# Includes
source $VESTA/func/main.sh
source $VESTA/func/domain.sh
source $VESTA/func/ip.sh
source $VESTA/func/vx/proxy.sh
source $VESTA/conf/vesta.conf

# Additional argument formatting
format_domain
format_domain_idn


#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '4' "$#" 'USER DOMAIN MODE TARGET [PROFILE] [PRESERVE_HOST] [TIMEOUT] [HEADERS] [RESTART]'
is_format_valid 'user' 'domain'
is_system_enabled "$PROXY_SYSTEM" 'PROXY_SYSTEM'
is_object_valid 'user' 'USER' "$user"
is_object_unsuspended 'user' 'USER' "$user"
is_object_valid 'web' 'DOMAIN' "$domain"
is_object_unsuspended 'web' 'DOMAIN' "$domain"
is_proxy_template_valid "$VX_PROXY_TEMPLATE"


#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Parsing domain values
get_domain_values 'web'
vx_proxy_apply_positional_globals "$mode" "$target" "$profile" "$preserve_host" "$timeout" "$headers"
vx_proxy_validate
local_ip=$(get_real_ip $IP)

# Delete old proxy vhost when present
if [ -n "$PROXY" ]; then
    del_web_config "$PROXY_SYSTEM" "$PROXY.tpl"
    if [ "$SSL" = 'yes' ]; then
        del_web_config "$PROXY_SYSTEM" "$PROXY.stpl"
    fi
fi

# Add native proxy vhost
PROXY="$VX_PROXY_TEMPLATE"
[ -n "$PROXY_EXT" ] || PROXY_EXT="$default_extentions"
prepare_web_domain_values
add_web_config "$PROXY_SYSTEM" "$PROXY.tpl"
if [ "$SSL" = 'yes' ]; then
    add_web_config "$PROXY_SYSTEM" "$PROXY.stpl"
fi


#----------------------------------------------------------#
#                       Vesta                              #
#----------------------------------------------------------#

# Updating config
update_object_value 'web' 'DOMAIN' "$domain" '$PROXY' "$PROXY"
update_object_value 'web' 'DOMAIN' "$domain" '$PROXY_EXT' "$PROXY_EXT"
vx_proxy_update_web_conf

# Restarting proxy
$BIN/v-restart-proxy $restart
check_result $? "Proxy restart failed" >/dev/null

# Logging
log_history "changed native proxy options for $domain"
log_event "$OK" "$ARGUMENTS"

exit
